# ─────────────────────────────────────────────────────────────
# OS
# ─────────────────────────────────────────────────────────────
.AppleDouble
.LSOverride
$RECYCLE.BIN/
ehthumbs.db

# ─────────────────────────────────────────────────────────────
# Docs build outputs (regenerable)
# ─────────────────────────────────────────────────────────────
docs/_build/
docs/site/
docs/api/_autogen/

# Don't ignore the proposal .docx (user-authored research artefact, small file)
!docs/proposal/*.docx
!docs/proposal/*.txt

# Office lock files (created when Word/Excel has the file open)
~$*
.~lock.*

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.cache/
