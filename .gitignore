.ruff_cache/
.pyre/
.pytype/

# ─────────────────────────────────────────────────────────────
# Jupyter
# ─────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

