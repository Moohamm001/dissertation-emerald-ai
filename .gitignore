# ─────────────────────────────────────────────────────────────
# Proprietary / sensitive — NEVER commit
# ─────────────────────────────────────────────────────────────
# Raw and intermediate data (proprietary green-loan dataset)
data/raw/**
data/interim/**
data/processed/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/**/README.md
*.xlsx
*.xls
*.csv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib

# Supervisor's reference document (private; do not redistribute)
docs/proposal/proposal_tatphong.pdf

# Trained models + experiment artefacts
# Anchored with leading slash so /models/ (top-level) is excluded but
# src/emerald_ai/models/ (source package) is NOT.
/models/
mlruns/
mlartifacts/
catboost_info/
*.onnx
*.pt
*.pth
*.ckpt
*.safetensors

# DVC
.dvc/cache
.dvc/tmp

# Research-bot HTTP cache (regenerable; large; gitignored)
research/literature/state/cache/

# ─────────────────────────────────────────────────────────────
# Secrets & local config
# ─────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
.secrets/
credentials.json
service-account*.json

# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.uv/

