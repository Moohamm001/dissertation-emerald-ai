# Auto-detect text files and normalise line endings to LF
* text=auto eol=lf

# Force LF for cross-platform text files
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf
Makefile text eol=lf

# Treat as binary (no normalisation, no diffs)
*.docx  binary
*.pdf   binary
*.xlsx  binary
*.xls   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pkl   binary
*.joblib binary
*.parquet binary

# Generated docx: small file, full diff not useful but include in git
docs/proposal/*.docx -diff
